PORT=8787
HOST=0.0.0.0
NODE_ENV=production
PUBLIC_BASE_URL=https://ai.appkaola.com
CORS_ALLOWED_ORIGINS=https://ai.appkaola.com
ADMIN_API_TOKEN=change-this-long-random-token

# PostgreSQL is optional at runtime while JSON fallback is kept.
DATABASE_URL=postgres://ai_shorta:change-me@postgres:5432/ai_shorta
DB_DUAL_WRITE=1
DB_IMPORT_JSON_ON_START=0
# Keep json until imports and backups are verified, then switch to postgres.
DB_READ_PRIMARY=json
DATABASE_WAIT_ATTEMPTS=30
DATABASE_WAIT_DELAY_MS=2000

IMAGE_JOB_CONCURRENCY=2
IMAGE_JOB_REQUEST_TIMEOUT_SECONDS=600
VIDEO_JOB_REQUEST_TIMEOUT_SECONDS=1800
JSON_BODY_LIMIT=50mb
TRUST_PROXY=loopback
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=300

# Enable object storage in production for shared, durable uploads.
OBJECT_STORAGE_ENABLED=1
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_PUBLIC_BASE_URL=
